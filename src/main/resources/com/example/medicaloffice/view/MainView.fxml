<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.medicaloffice.controller.MainController">

    <center>
        <TabPane>
            <!-- Tab: Ασθενείς -->
            <Tab text="Ασθενείς" closable="false">
                <VBox spacing="10">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>

                    <Label text="Προσθήκη Νέου Ασθενούς" styleClass="form-title"/>

                    <VBox styleClass="form-card">
                        <GridPane hgap="15" vgap="12">
                            <Label text="Όνομα *" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                            <TextField fx:id="patientNameField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                            <Label text="Επίθετο *" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                            <TextField fx:id="patientSurnameField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                            <Label text="Τηλέφωνο *" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                            <TextField fx:id="patientPhoneField" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                            <Label text="Email *" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                            <TextField fx:id="patientEmailField" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                            <Label text="Ημ. Γέννησης *" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                            <DatePicker fx:id="patientBirthDatePicker" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                            <Label text="ΑΜΚΑ *" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                            <TextField fx:id="patientAmkaField" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                            <Label text="Ιατρικό Ιστορικό" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                            <TextArea fx:id="patientHistoryArea" GridPane.columnIndex="1" GridPane.rowIndex="6" prefHeight="60" prefWidth="300"/>

                            <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="7">
                                <Button text="Αποθήκευση" onAction="#handleAddPatient" styleClass="button-primary"/>
                                <Button text="Καθαρισμός" onAction="#handleClearPatientForm"/>
                                <Button text="Εξαγωγή CSV" onAction="#exportPatientsToCSV" styleClass="button"/>
                            </HBox>
                        </GridPane>
                        <!-- Hidden field for patient ID (used for editing) -->
                        <TextField fx:id="patientIdField" visible="false" managed="false"/>
                    </VBox>

                    <Separator/>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Αναζήτηση:"/>
                        <TextField fx:id="patientSearchField" promptText="ID, Όνομα, Επίθετο, ΑΜΚΑ..." HBox.hgrow="ALWAYS"/>
                        <Button text="Αναζήτηση" onAction="#searchPatients" styleClass="button-primary"/>
                        <Button text="Καθαρισμός" onAction="#resetPatientSearch"/>
                    </HBox>

                    <Label text="Λίστα Ασθενών" styleClass="form-title"/>
                    <TableView fx:id="patientsTable" prefHeight="250">
                        <columns>
                            <TableColumn text="ID" fx:id="patientIdColumn" prefWidth="80"/>
                            <TableColumn text="Όνομα" fx:id="patientNameColumn" prefWidth="120"/>
                            <TableColumn text="Επίθετο" fx:id="patientSurnameColumn" prefWidth="120"/>
                            <TableColumn text="Τηλέφωνο" fx:id="patientPhoneColumn" prefWidth="100"/>
                            <TableColumn text="Email" fx:id="patientEmailColumn" prefWidth="160"/>
                            <TableColumn text="ΑΜΚΑ" fx:id="patientAmkaColumn" prefWidth="120"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </Tab>

            <!-- Tab: Ιατροί -->
            <Tab text="Ιατροί" closable="false">
                <VBox spacing="10">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>

                    <Label text="Προσθήκη Νέου Ιατρού" styleClass="form-title"/>

                    <VBox styleClass="form-card">
                        <GridPane hgap="15" vgap="12">
                            <Label text="Όνομα *" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                            <TextField fx:id="doctorNameField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                            <Label text="Επίθετο *" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                            <TextField fx:id="doctorSurnameField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                            <Label text="Τηλέφωνο *" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                            <TextField fx:id="doctorPhoneField" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                            <Label text="Email *" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                            <TextField fx:id="doctorEmailField" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                            <Label text="Ημ. Γέννησης *" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                            <DatePicker fx:id="doctorBirthDatePicker" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                            <Label text="Ειδικότητα *" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                            <ComboBox fx:id="doctorSpecialtyCombo" GridPane.columnIndex="1" GridPane.rowIndex="5" prefWidth="200"/>

                            <Label text="Αριθμός Άδειας *" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                            <TextField fx:id="doctorLicenseField" GridPane.columnIndex="1" GridPane.rowIndex="6"/>

                            <Label text="Ιατρείο *" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
                            <TextField fx:id="doctorOfficeField" GridPane.columnIndex="1" GridPane.rowIndex="7"/>

                            <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="8">
                                <Button text="Αποθήκευση" onAction="#handleAddDoctor" styleClass="button-primary"/>
                                <Button text="Καθαρισμός" onAction="#handleClearDoctorForm"/>
                                <Button text="Εξαγωγή CSV" onAction="#exportDoctorsToCSV" styleClass="button"/>
                            </HBox>
                        </GridPane>
                        <!-- Hidden field for doctor ID (used for editing) -->
                        <TextField fx:id="doctorIdField" visible="false" managed="false"/>
                    </VBox>

                    <Separator/>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Αναζήτηση:"/>
                        <TextField fx:id="doctorSearchField" promptText="ID, Όνομα, Επίθετο, Ειδικότητα..." HBox.hgrow="ALWAYS"/>
                        <Button text="Αναζήτηση" onAction="#searchDoctors" styleClass="button-primary"/>
                        <Button text="Καθαρισμός" onAction="#resetDoctorSearch"/>
                    </HBox>

                    <Label text="Λίστα Ιατρών" styleClass="form-title"/>
                    <TableView fx:id="doctorsTable" prefHeight="200">
                        <columns>
                            <TableColumn text="ID" fx:id="doctorIdColumn" prefWidth="80"/>
                            <TableColumn text="Όνομα" fx:id="doctorNameColumn" prefWidth="120"/>
                            <TableColumn text="Επίθετο" fx:id="doctorSurnameColumn" prefWidth="120"/>
                            <TableColumn text="Ειδικότητα" fx:id="doctorSpecialtyColumn" prefWidth="150"/>
                            <TableColumn text="Τηλέφωνο" fx:id="doctorPhoneColumn" prefWidth="100"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </Tab>

            <!-- Tab: Ραντεβού -->
            <Tab text="Ραντεβού" closable="false">
                <VBox spacing="10">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>

                    <Label text="Κλείσιμο Νέου Ραντεβού" styleClass="form-title"/>

                    <VBox styleClass="form-card">
                        <GridPane hgap="15" vgap="12">
                            <Label text="Ασθενής *" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                            <ComboBox fx:id="appointmentPatientCombo" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="250"/>

                            <Label text="Ιατρός *" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                            <ComboBox fx:id="appointmentDoctorCombo" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="250"/>

                            <Label text="Ημερομηνία *" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                            <DatePicker fx:id="appointmentDatePicker" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                            <Label text="Ώρα *" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                            <TextField fx:id="appointmentTimeField" GridPane.columnIndex="1" GridPane.rowIndex="3" promptText="HH:MM"/>

                            <Label text="Λόγος Επίσκεψης" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                            <TextField fx:id="appointmentReasonField" GridPane.columnIndex="1" GridPane.rowIndex="4" prefWidth="300"/>

                            <Label text="Σημειώσεις" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                            <TextArea fx:id="appointmentNotesArea" GridPane.columnIndex="1" GridPane.rowIndex="5" prefHeight="60" prefWidth="300"/>

                            <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="6">
                                <Button text="Κλείσιμο Ραντεβού" onAction="#handleAddAppointment" styleClass="button-primary"/>
                                <Button text="Καθαρισμός" onAction="#handleClearAppointmentForm"/>
                                <Button text="Εξαγωγή CSV" onAction="#exportAppointmentsToCSV" styleClass="button"/>
                            </HBox>
                        </GridPane>
                    </VBox>

                    <Separator/>

                    <HBox spacing="10">
                        <Label text="Αναζήτηση:"/>
                        <TextField fx:id="searchField" promptText="Αναζήτηση με όνομα ασθενούς, ιατρού ή λόγο..." HBox.hgrow="ALWAYS"/>
                        <Button text="Αναζήτηση" onAction="#handleSearchAppointments" styleClass="button-primary"/>
                        <Button text="Σήμερα" onAction="#handleTodayAppointments"/>
                        <Button text="Όλα" onAction="#handleShowAllAppointments"/>
                    </HBox>

                    <TableView fx:id="appointmentsTable" prefHeight="280">
                        <columns>
                            <TableColumn text="ID" fx:id="appointmentIdColumn" prefWidth="80"/>
                            <TableColumn text="Ασθενής" fx:id="appointmentPatientColumn" prefWidth="160"/>
                            <TableColumn text="Ιατρός" fx:id="appointmentDoctorColumn" prefWidth="160"/>
                            <TableColumn text="Ημερομηνία / Ώρα" fx:id="appointmentDateTimeColumn" prefWidth="140"/>
                            <TableColumn text="Λόγος" fx:id="appointmentReasonColumn" prefWidth="200"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </Tab>

            <!-- Tab: Ημερολόγιο (ΝΕΟ) -->
            <Tab text="Ημερολόγιο" closable="false">
                <VBox spacing="10">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>

                    <!-- Toolbar -->
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <Button text="◄ Προηγ." onAction="#previousMonth" styleClass="button"/>
                        <Label fx:id="monthYearLabel" text="Ιανουάριος 2025" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                        <Button text="Επόμ. ►" onAction="#nextMonth" styleClass="button"/>
                        <Button text="Σήμερα" onAction="#today" styleClass="button-primary"/>
                    </HBox>

                    <Separator/>

                    <!-- Grid για τις ημέρες (θα γεμίσει από Java) -->
                    <GridPane fx:id="calendarGrid" hgap="8" vgap="8">
                        <!-- Οι ημέρες θα προστεθούν δυναμικά -->
                    </GridPane>

                    <Separator/>

                    <!-- Λίστα ραντεβού επιλεγμένης ημέρας -->
                    <Label text="📅 Ραντεβού επιλεγμένης ημέρας" styleClass="form-title"/>
                    <ListView fx:id="dayAppointmentsList" prefHeight="150">
                        <placeholder>
                            <Label text="Δεν υπάρχουν ραντεβού για αυτή την ημέρα"/>
                        </placeholder>
                    </ListView>

                </VBox>
            </Tab>

        </TabPane>
    </center>

    <bottom>
        <Label fx:id="statusLabel" text="Ready" styleClass="label-status">
            <padding>
                <Insets left="15" right="15"/>
            </padding>
        </Label>
    </bottom>

</BorderPane>