<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.medicaloffice.controller.MainController">


    <center>
        <TabPane fx:id="mainTabPane">
            <!-- Τα tabs θα γεμίσουν δυναμικά από το MainController -->
        </TabPane>
    </center>

    <bottom>
        <Label fx:id="statusLabel" text="Ready" styleClass="label-status">
            <padding>
                <Insets left="15" right="15"/>
            </padding>
        </Label>
    </bottom>

</BorderPane>