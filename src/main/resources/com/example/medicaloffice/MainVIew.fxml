<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.medicaloffice.controller.MainController">

    <top>
        <VBox>
            <MenuBar>
                <Menu text="Αρχείο">
                    <MenuItem text="Αποθήκευση" onAction="#handleSave"/>
                    <MenuItem text="Φόρτωση" onAction="#handleLoad"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Έξοδος" onAction="#handleExit"/>
                </Menu>
                <Menu text="Προβολή">
                    <MenuItem text="Όλα τα Ραντεβού" onAction="#handleShowAllAppointments"/>
                    <MenuItem text="Ραντεβού Σήμερα" onAction="#handleTodayAppointments"/>
                </Menu>
                <Menu text="Βοήθεια">
                    <MenuItem text="Σχετικά" onAction="#handleAbout"/>
                </Menu>
            </MenuBar>
            <Label text="Σύστημα Διαχείρισης Ιατρείου" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-background-color: #2c3e50; -fx-text-fill: white; -fx-padding: 10px;" maxWidth="Infinity"/>
        </VBox>
    </top>

    <center>
        <TabPane>
            <!-- Tab: Ασθενείς -->
            <Tab text="Ασθενείς" closable="false">
                <VBox spacing="10" padding="10">
                    <Label text="Προσθήκη Νέου Ασθενούς" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <GridPane hgap="10" vgap="10">
                        <Label text="ID:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="patientIdField" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="200"/>

                        <Label text="Όνομα:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <TextField fx:id="patientNameField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <Label text="Επίθετο:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <TextField fx:id="patientSurnameField" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                        <Label text="Τηλέφωνο:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                        <TextField fx:id="patientPhoneField" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                        <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                        <TextField fx:id="patientEmailField" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                        <Label text="Ημ. Γέννησης:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                        <DatePicker fx:id="patientBirthDatePicker" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                        <Label text="ΑΜΚΑ:" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                        <TextField fx:id="patientAmkaField" GridPane.columnIndex="1" GridPane.rowIndex="6"/>

                        <Label text="Ιατρικό Ιστορικό:" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
                        <TextArea fx:id="patientHistoryArea" GridPane.columnIndex="1" GridPane.rowIndex="7" prefHeight="60" prefWidth="300"/>

                        <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="8">
                            <Button text="Προσθήκη" onAction="#handleAddPatient" style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
                            <Button text="Καθαρισμός" onAction="#handleClearPatientForm"/>
                        </HBox>
                    </GridPane>

                    <Separator/>

                    <Label text="Λίστα Ασθενών" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <TableView fx:id="patientsTable" prefHeight="250">
                        <columns>
                            <TableColumn text="ID" fx:id="patientIdColumn" prefWidth="60"/>
                            <TableColumn text="Όνομα" fx:id="patientNameColumn" prefWidth="100"/>
                            <TableColumn text="Επίθετο" fx:id="patientSurnameColumn" prefWidth="100"/>
                            <TableColumn text="Τηλέφωνο" fx:id="patientPhoneColumn" prefWidth="100"/>
                            <TableColumn text="Email" fx:id="patientEmailColumn" prefWidth="150"/>
                            <TableColumn text="ΑΜΚΑ" fx:id="patientAmkaColumn" prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <!-- Tab: Ιατροί -->
            <Tab text="Ιατροί" closable="false">
                <VBox spacing="10" padding="10">
                    <Label text="Προσθήκη Νέου Ιατρού" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <GridPane hgap="10" vgap="10">
                        <Label text="ID:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="doctorIdField" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="200"/>

                        <Label text="Όνομα:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <TextField fx:id="doctorNameField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <Label text="Επίθετο:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <TextField fx:id="doctorSurnameField" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                        <Label text="Τηλέφωνο:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                        <TextField fx:id="doctorPhoneField" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                        <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                        <TextField fx:id="doctorEmailField" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                        <Label text="Ημ. Γέννησης:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                        <DatePicker fx:id="doctorBirthDatePicker" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                        <Label text="Ειδικότητα:" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                        <ComboBox fx:id="doctorSpecialtyCombo" GridPane.columnIndex="1" GridPane.rowIndex="6" prefWidth="200"/>

                        <Label text="Αριθμός Άδειας:" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
                        <TextField fx:id="doctorLicenseField" GridPane.columnIndex="1" GridPane.rowIndex="7"/>

                        <Label text="Ιατρείο:" GridPane.columnIndex="0" GridPane.rowIndex="8"/>
                        <TextField fx:id="doctorOfficeField" GridPane.columnIndex="1" GridPane.rowIndex="8"/>

                        <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="9">
                            <Button text="Προσθήκη" onAction="#handleAddDoctor" style="-fx-background-color: #2980b9; -fx-text-fill: white;"/>
                            <Button text="Καθαρισμός" onAction="#handleClearDoctorForm"/>
                        </HBox>
                    </GridPane>

                    <Separator/>

                    <Label text="Λίστα Ιατρών" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <TableView fx:id="doctorsTable" prefHeight="200">
                        <columns>
                            <TableColumn text="ID" fx:id="doctorIdColumn" prefWidth="60"/>
                            <TableColumn text="Όνομα" fx:id="doctorNameColumn" prefWidth="100"/>
                            <TableColumn text="Επίθετο" fx:id="doctorSurnameColumn" prefWidth="100"/>
                            <TableColumn text="Ειδικότητα" fx:id="doctorSpecialtyColumn" prefWidth="120"/>
                            <TableColumn text="Τηλέφωνο" fx:id="doctorPhoneColumn" prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <!-- Tab: Ραντεβού -->
            <Tab text="Ραντεβού" closable="false">
                <VBox spacing="10" padding="10">
                    <Label text="Κλείσιμο Νέου Ραντεβού" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <GridPane hgap="10" vgap="10">
                        <Label text="Ασθενής:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <ComboBox fx:id="appointmentPatientCombo" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="250"/>

                        <Label text="Ιατρός:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <ComboBox fx:id="appointmentDoctorCombo" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="250"/>

                        <Label text="Ημερομηνία:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <DatePicker fx:id="appointmentDatePicker" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                        <Label text="Ώρα (HH:MM):" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                        <TextField fx:id="appointmentTimeField" GridPane.columnIndex="1" GridPane.rowIndex="3" promptText="π.χ. 14:30"/>

                        <Label text="Λόγος Επίσκεψης:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                        <TextField fx:id="appointmentReasonField" GridPane.columnIndex="1" GridPane.rowIndex="4" prefWidth="300"/>

                        <Label text="Σημειώσεις:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                        <TextArea fx:id="appointmentNotesArea" GridPane.columnIndex="1" GridPane.rowIndex="5" prefHeight="60" prefWidth="300"/>

                        <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="6">
                            <Button text="Κλείσιμο Ραντεβού" onAction="#handleAddAppointment" style="-fx-background-color: #e67e22; -fx-text-fill: white;"/>
                            <Button text="Καθαρισμός" onAction="#handleClearAppointmentForm"/>
                        </HBox>
                    </GridPane>

                    <Separator/>

                    <HBox spacing="10">
                        <Label text="Αναζήτηση:"/>
                        <TextField fx:id="searchField" promptText="Αναζήτηση με όνομα ασθενούς, ιατρού ή λόγο..." HBox.hgrow="ALWAYS"/>
                        <Button text="Αναζήτηση" onAction="#handleSearchAppointments"/>
                        <Button text="Ραντεβού Σήμερα" onAction="#handleTodayAppointments"/>
                        <Button text="Όλα" onAction="#handleShowAllAppointments"/>
                    </HBox>

                    <TableView fx:id="appointmentsTable" prefHeight="280">
                        <columns>
                            <TableColumn text="ID" fx:id="appointmentIdColumn" prefWidth="80"/>
                            <TableColumn text="Ασθενής" fx:id="appointmentPatientColumn" prefWidth="150"/>
                            <TableColumn text="Ιατρός" fx:id="appointmentDoctorColumn" prefWidth="150"/>
                            <TableColumn text="Ημερομηνία/Ώρα" fx:id="appointmentDateTimeColumn" prefWidth="130"/>
                            <TableColumn text="Λόγος" fx:id="appointmentReasonColumn" prefWidth="150"/>
                            <TableColumn text="Ολοκληρώθηκε" fx:id="appointmentStatusColumn" prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>
        </TabPane>
    </center>

    <bottom>
        <Label fx:id="statusLabel" text="Ready" style="-fx-background-color: #ecf0f1; -fx-padding: 8px; -fx-border-color: #bdc3c7; -fx-border-width: 1 0 0 0;">
            <padding>
                <Insets left="10" right="10"/>
            </padding>
        </Label>
    </bottom>
</BorderPane>